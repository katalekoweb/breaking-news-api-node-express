    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        },
        "schemas": {
            "User": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name of the user"
                    },
                    "username": {
                        "type": "string",
                        "description": "The username of the user"
                    },
                    "email": {
                        "type": "string",
                        "description": "The email of the user"
                    },
                    "password": {
                        "type": "string",
                        "description": "The password of the user"
                    },
                    "avatar": {
                        "type": "string",
                        "description": "The avatar URL of the user"
                    },
                    "background": {
                        "type": "string",
                        "description": "The background URL of the user"
                    }
                },
                "required": ["name", "username", "email", "password"]
            },
            "Post": {
                "type": "object",
                "properties": {
                    "title": {
                        "type": "string",
                        "description": "The title of the post"
                    },
                    "content": {
                        "type": "string",
                        "description": "The content of the post"
                    },
                    "user": {
                        "type": "string",
                        "description": "The user of the post"
                    },
                    "banner": {
                        "type": "string",
                        "description": "The banner URL of the post"
                    },
                    "likes": {
                        "type": "array"
                    },
                    "comments": {
                        "type": "array"
                    },
                    "createdAt": {
                        "type": "date"
                    }
                },
                "required": ["title", "content", "user"]
            },
            "Comment": {
                "type": "object",
                "properties": {
                    "comment": {
                        "type": "string",
                        "description": "The content of the comment"
                    },
                    "user": {
                        "type": "string",
                        "description": "The user of the comment"
                    }
                },
                "required": ["comment", "user"]
            }
        }
    }
